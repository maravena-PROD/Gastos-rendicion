# Google Service Account (crear en Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-sa@tu-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# ID de la planilla de Google Sheets (de la URL de la planilla)
GOOGLE_SHEETS_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# API key de Anthropic (Plan 3)
ANTHROPIC_API_KEY=sk-ant-...

# Admin key de Anthropic — para revisar el gasto de la API ('npm run creditos'
# y el panel de gasto en el dashboard). Es distinta de la API key normal: se
# genera en Settings -> Admin keys. Es org-wide y potente: úsala solo en el
# servidor (en Vercel: Environment Variables, NO con prefijo NEXT_PUBLIC_).
# Opcional: si no la pones, el bot funciona igual; solo no verás el gasto.
ANTHROPIC_ADMIN_KEY=sk-ant-admin...
# Presupuesto mensual en USD para la alerta de gasto (opcional, solo el script). Ej: 20
ANTHROPIC_BUDGET_USD=20
# Email del ÚNICO usuario que puede ver el panel de gasto en el dashboard.
# Si no se configura, el panel no se muestra a nadie.
ANTHROPIC_COST_VIEWER_EMAIL=maravena@bosca.cl

# Firebase — cliente (público, se expone al navegador con prefijo NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto

# Firebase Admin — servidor. Reusa GOOGLE_SERVICE_ACCOUNT_EMAIL y GOOGLE_PRIVATE_KEY
# de arriba (la service account debe pertenecer al mismo proyecto que Firebase Auth).
# project_id de Firebase (normalmente igual al del proyecto de Google Cloud):
FIREBASE_PROJECT_ID=tu-proyecto

# Google Drive — ID de la carpeta donde se guardan las imágenes de boletas
# (de la URL de la carpeta; compártela con la service account como Editor).
# NOTA: cada imagen subida queda con acceso de lectura "cualquiera con el link"
# (no protegida por sesión). Si la URL se filtra, la boleta queda expuesta.
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz
